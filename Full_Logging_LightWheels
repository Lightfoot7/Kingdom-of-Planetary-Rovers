// CONVERT MOTOR PWM TO HARDWARE PWM
void ApplyMotorPWM(){
    for (int i =0; i<6; i++){
        //Convert 0-255 to 0-1200 (BUT INVERTED!!!!!!!!!!!!)
        int DUTY = (int) map(MotorPWM[i], 0, 255, 1200, 0);  // cuz map returns long

        PWMC_SetDutyCycle(PWM, PWM_Channel[i], DUTY);
    }
}

