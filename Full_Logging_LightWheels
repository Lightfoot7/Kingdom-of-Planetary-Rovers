#include <SPI.h>
#include <SD.h>

// 1 :) ENCODER HAKI (6 MOTORS)
// use volatile so brain processor sees every tiny movement instantly
volatile long counts[6] = {0, 0, 0, 0, 0, 0};

// Interrupt ISR Functions so it makes it count pulses at lightfoot speed mode 
void ISR_MOTOR_1() { counts[0]++; }
void ISR_MOTOR_2() { counts[1]++; }
void ISR_MOTOR_3() { counts[2]++; }
void ISR_MOTOR_4() { counts[3]++; }
void ISR_MOTOR_5() { counts[4]++; }
void ISR_MOTOR_6() { counts[5]++; }

int MotorPWM[6] = {0, 0, 0, 0, 0, 0};  // Current SPEED being sent to each motor from a range of 0 to 255
const int EncoderPins[6] = {22, 23, 24, 25, 26, 27};

// 2 ;) IMU & LOGGING GEAR
const int chipselect =  10;
const int ledPin = 13;
unsigned long previousMillis = 0;
const long interval = 10; // 10 ms = 100 Hz frequency babyyy

float Roll = 0, Pitch = 0, Yaw = 0;

void setup(){
    Serial.begin(115200);  // Laptop
    Serial1.begin(115200); // IMU (WT901C)
    pinMode(ledPin, OUTPUT);

    // Initialise Encoders with pullups
    for(int i = 0; i < 6; i++){
        pinMode(EncoderPins[i], INPUT_PULLUP);
    }
    attachInterrupt(digitalPinToInterrupt(EncoderPins[0]), ISR_MOTOR_1, RISING);
    attachInterrupt(digitalPinToInterrupt(EncoderPins[1]), ISR_MOTOR_2, RISING);
    attachInterrupt(digitalPinToInterrupt(EncoderPins[2]), ISR_MOTOR_3, RISING);
    attachInterrupt(digitalPinToInterrupt(EncoderPins[3]), ISR_MOTOR_4, RISING);
    attachInterrupt(digitalPinToInterrupt(EncoderPins[4]), ISR_MOTOR_5, RISING);
    attachInterrupt(digitalPinToInterrupt(EncoderPins[5]), ISR_MOTOR_6, RISING);

    // Initialise SD card
    if(!SD.begin(chipselect)){
        while (1){ // SOS Flash if SD fails 
            digitalWrite(ledPin, HIGH); delay(100); digitalWrite(ledPin, LOW); delay(100);
        }   
    }

    // SEND THE 100 Hz COMMAND TO IMU (The 5-byte NINJA RASENGAN SCROLL)
    byte Rasengan[] = {0xFF, 0xAA, 0x03, 0x03, 0x00};
    Serial1.write(Rasengan, 5);

    // Create CSV Header for Sarah
    File DataFile = SD.open("LightWheels_Rover.csv", FILE_WRITE);
    if (DataFile){
        DataFile.println("Time_ms,Roll,Pitch,Yaw,M1_Count,M2_Count,M3_Count,M4_Count,M5_Count,M6_Count,V1_PWM,V2_PWM,V3_PWM,V4_PWM,V5_PWM,V6_PWM");
        DataFile.close();
    }   
}

void loop(){
    unsigned long currentMillis = millis();

    // Always listen for IMU data in the background
    ReadIMU();

    // The 100 Hz Heartbeat DRUMS OF LIBERATION: Log every 10 ms
    if (currentMillis - previousMillis >= interval){
        previousMillis = currentMillis;
        LogData(currentMillis);
    }
 }

void ReadIMU() {
    // Check if we have a full 11-byte packet waiting
    if (Serial1.available() >= 11){
        if (Serial1.read() == 0x55){ // Header
            byte type = Serial1.read();
            if (type == 0x53) { // Euler Angles
            int16_t rRaw = (Serial1.read() | (Serial1.read() << 8));
            int16_t pRaw = (Serial1.read() | (Serial1.read() << 8));
            int16_t yRaw = (Serial1.read() | (Serial1.read() << 8));

            // Discard temperature and checksum
            for(int i=0; i<3; i++) Serial1.read();

            // Convert to human degrees
            Roll = (float)rRaw / 32768.0 * 180.0;
            Pitch = (float)pRaw / 32768.0 * 180.0;
            Yaw = (float)yRaw / 32768.0 * 180.0;

        } 
     }
   }
}

void LogData(unsigned long TimeStamp) {
  File DataFile =  SD.open("LightWheels_Rover.csv", FILE_WRITE);
  if (DataFile) {
     digitalWrite(LedPin, HIGH);  // GREEN LIGHT: LOGGING ACTIVE!

     DataFile.print(TimeStamp); DataFile.print(",");
     DataFile.print(Roll); DataFile.print(",");
     DataFile.print(Pitch); DataFile.print(",");
     DataFile.print(Yaw); DataFile.print(",");

     // Log all 6 encoder counts
     for(int i = 0; i < 6; i++){
        DataFile.print(counts[i]);
        DataFile.print(",");             // a comma to seperate data
      }

     // Log THE PWM / Voltage INPUTS FOR ALL 6 motors
     for(int i = 0; i < 6; i++){
         DataFile.print(MotorPWM[i]);
         if(i<5) DataFile.print(",");
     }

     DataFile.println();
     DataFile.close();
     digitalWrite(ledPin, LOW);         // LIGHT OFF: SD ERROR!
    } 
}
